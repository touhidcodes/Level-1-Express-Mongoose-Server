{
  "name": "level-1-express-mongoose-server",
  "version": "1.0.0",
  "description": "Basic Express Mongoose Typescript Boilerplate for an Event Management Platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
